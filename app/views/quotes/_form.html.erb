<%= form_with model: quote do |form| %>
  <% if quote.errors.any? %>
    <div class="error-box">
      <p><strong><%= pluralize(quote.errors.count, "erreur") %> a empêché le devis d'être enregistré :</strong></p>
      <ul>
        <% quote.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field-row">
    <%= form.label :name, "Nom" %>
    <%= form.text_field :name, required: true %>
  </div>

  <div class="actions">
    <%= form.submit "Enregistrer" %>
    <%= link_to "Annuler", quote.persisted? ? quote_path(quote) : quotes_path %>
  </div>
<% end %>
