<div class="page">
  <div class="header-row">
    <h1>Mes Devis</h1>
  </div>
  <% if @quotes.empty? %>
    <p>Aucun devis trouvé.</p>
  <% else %>
    <div class="quotes-list">
      <div class="quote-row quote-row-header">
        <span>ID</span>
        <span>Date</span>
        <span>Nom</span>
        <span></span>
      </div>

      <% @quotes.each do |quote| %>
        <div class="quote-row">
          <span><%= quote.id %></span>
          <span><%= localize quote.created_at, format: :short %></span>
          <span><%= quote.name %></span>
          <span class="actions-line">
            <% if quote.editable? %>
              <%= link_to "Editer", quote_path(quote) %>
              <%= button_to "Supprimer", quote_path(quote), method: :delete, form: { data: { turbo_confirm: "Supprimer ce devis ?" } } %>
            <% else %>
              <%= link_to "Afficher", quote_path(quote) %>
            <% end %>
          </span>
        </div>
      <% end %>
    </div>
  <% end %>

  <h2>Ajouter un devis</h2>
  <%= render "form", quote: @quote %>
</div>
