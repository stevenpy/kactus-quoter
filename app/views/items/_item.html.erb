<%= turbo_frame_tag dom_id(item) do %>
  <div class="item-row">
    <span><%= item.name %></span>
    <span><%= item.quantity %></span>
    <span><%= euros_from_cents(item.unit_price_cents) %></span>
    <span><%= number_with_precision(item.vat_rate, precision: 2) %>%</span>
    <span><%= euros_from_cents(item.subtotal_excl_vat_cents) %></span>
    <span><%= euros_from_cents(item.total_incl_vat_cents) %></span>
    <span class="actions-line">
      <% if quote.editable? %>
        <%= link_to "Modifier", edit_quote_item_path(quote, item), data: { turbo_frame: dom_id(item) } %>
        <%= button_to "Supprimer", quote_item_path(quote, item), method: :delete, form: { data: { turbo_confirm: "Supprimer cet article ?" } } %>
      <% end %>
    </span>
  </div>
<% end %>
