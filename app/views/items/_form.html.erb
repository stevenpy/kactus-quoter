<%= form_with model: [quote, item], class: "item-form" do |form| %>
  <% if item.errors.any? %>
    <div class="error-box">
      <p><strong><%= pluralize(item.errors.count, "erreur") %> a empêché l'article d'être enregistré :</strong></p>
      <ul>
        <% item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="item-form-row">
    <%= form.text_field :name, required: true, placeholder: "Titre de l'article" %>
    <%= form.number_field :quantity, min: 1, step: 1, required: true, placeholder: "Quantité" %>
    <%= form.number_field :unit_price_cents, min: 0, step: 1, required: true, placeholder: "Montant" %>
    <%= form.number_field :vat_rate, min: 0, max: 100, step: 0.01, required: true, placeholder: "TVA" %>
    <span class="item-form-total">
      <%= item.persisted? ? euros_from_cents(item.subtotal_excl_vat_cents) : "Total HT" %>
    </span>
    <span class="item-form-total">
      <%= item.persisted? ? euros_from_cents(item.total_incl_vat_cents) : "Total TTC" %>
    </span>
    <span class="actions-line">
      <%= form.submit "Enregistrer" %>
      <%= link_to "Annuler", quote_path(quote) %>
    </span>
  </div>
<% end %>
