<%= form_with model: [quote, item], data: { controller: "item-total" } do |form| %>
  <% if item.errors.any? %>
    <div class="error-box">
      <p><strong><%= pluralize(item.errors.count, "erreur") %> a empêché l'article d'être enregistré :</strong></p>
      <ul>
        <% item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid-form">
    <div>
      <%= form.label :name, "Nom" %>
      <%= form.text_field :name, required: true %>
    </div>
    <div>
      <%= form.label :quantity, "Quantité" %>
      <%= form.number_field :quantity, min: 1, step: 1, required: true, data: { item_total_target: "quantity", action: "input->item-total#recalculate" } %>
    </div>
    <div>
      <%= form.label :unit_price_cents, "Prix unitaire (HT, cents)" %>
      <%= form.number_field :unit_price_cents, min: 0, step: 1, required: true, data: { item_total_target: "unitPrice", action: "input->item-total#recalculate" } %>
    </div>
    <div>
      <%= form.label :vat_rate, "Taux de TVA (%)" %>
      <%= form.number_field :vat_rate, min: 0, max: 100, step: 0.01, required: true, data: { item_total_target: "vatRate", action: "input->item-total#recalculate" } %>
    </div>
  </div>

  <div class="actions">
    <%= form.submit "Enregistrer" %>
    <%= link_to "Annuler", quote_path(quote) %>
  </div>
<% end %>
